{
  "model": {
    "path": "~/.cache/modelscope/hub/models/Qwen/Qwen3-32B",
    "dtype": "bf16",
    "seq_len": 512
  },
  "train": {
    "seed": 42,
    "steps": 4,
    "warmup_steps": 0,
    "global_batch_size": 8,
    "grad_accum_steps": 1,
    "lr": 0.0001,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "log_every": 1
  },
  "parallel": {
    "pp": {
      "degree": 4,
      "vpp": 1,
      "microbatches": 2,
      "schedule": "handrolled",
      "stages": [
        [0, 9],
        [10, 21],
        [22, 41],
        [42, 63]
      ]
    },
    "tp": {
      "enabled": false,
      "degree": 1
    },
    "sp": {
      "enabled": false
    },
    "fsdp2": {
      "enabled": false,
      "param_dtype": "bf16",
      "reduce_dtype": "bf16",
      "reshard_after_forward": false
    },
    "recompute": {
      "policy": "none",
      "per_stage": ["none", "none", "none", "none"]
    }
  },
  "runtime": {
    "cuda_alloc_conf": "expandable_segments:True",
    "dist_timeout_seconds": 3600,
    "debug_init_logs": true,
    "debug_module_logs": true,
    "debug_module_forward_limit": 8,
    "debug_module_loss_limit": 8,
    "debug_tp_loss_logs": true
  }
}
